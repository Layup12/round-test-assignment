{
  "name": "round",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "sync": "pnpm exec cap sync",
    "copy": "pnpm exec cap copy",
    "open:android": "pnpm exec cap open android",
    "open:ios": "pnpm exec cap open ios",
    "run:android": "pnpm exec cap run android",
    "run:ios": "pnpm exec cap run ios",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@tabler/icons-react": "^3.28.1",
    "@reduxjs/toolkit": "^2.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "react-virtualized": "^9.22.6",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^10.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.0.0",
    "postcss-preset-mantine": "^1.0.0",
    "postcss-simple-vars": "^7.0.0",
    "prettier": "^3.0.0",
    "sass-embedded": "^1.0.0",
    "sharp": "0.32.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,scss}": [
      "eslint",
      "prettier --check"
    ]
  }
}
